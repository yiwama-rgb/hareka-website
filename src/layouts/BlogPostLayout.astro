<script>
// 本文中途 CTA を自動挿入
(function() {
  const article = document.getElementById('article-body');
  if (!article) return;

  const ctaHTML = `<div class="prose-mid-cta">
    <p class="prose-mid-cta__text">💡 HubSpotの導入・活用でお困りですか？</p>
    <a href="https://hareka.io/contact" class="prose-mid-cta__btn">無料相談はこちら →</a>
  </div>`;

  const paragraphs = article.querySelectorAll('p');
  const mid = Math.floor(paragraphs.length / 2);
  const target = paragraphs[mid];
  if (target) {
    target.insertAdjacentHTML('afterend', ctaHTML);
  }
})();

// サイドバー TOC：スクロール連動でアクティブ表示
(function() {
  const links = document.querySelectorAll<HTMLAnchorElement>('.sidebar-toc__link');
  if (!links.length) return;

  const headings = Array.from(document.querySelectorAll<HTMLElement>('.prose h2, .prose h3'));
  if (!headings.length) return;

  const activate = () => {
    const scrollY = window.scrollY + 120;
    let current = '';
    for (const h of headings) {
      if (h.offsetTop <= scrollY) current = h.id;
    }
    links.forEach(l => {
      l.classList.toggle('active', l.getAttribute('href') === `#${current}`);
    });
  };

  window.addEventListener('scroll', activate, { passive: true });
  activate();
})();
</script>
