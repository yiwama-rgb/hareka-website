---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ['すべて', ...Array.from(new Set(allPosts.map(p => p.data.category)))];

// Reading time per post
const postMeta = allPosts.map(post => ({
  ...post,
  readTime: Math.max(1, Math.ceil(post.body.length / 400)),
}));

// Category gradient map (same as BlogPostLayout)
const categoryGradients: Record<string, { from: string; to: string; accent: string }> = {
  'HubSpot活用':     { from: '#1B3558', to: '#2D6A9F', accent: '#4D8DB5' },
  'CRM導入・移管':   { from: '#1B3558', to: '#1E5F74', accent: '#2E8B9A' },
  'AI・自動化':      { from: '#1A2B4A', to: '#2D3A6B', accent: '#5B6EC7' },
  'レポート・分析':  { from: '#1B3A2D', to: '#1E6B4A', accent: '#2EA87A' },
  'HubSpot基礎':     { from: '#3A1B1B', to: '#6B2D2D', accent: '#C75B5B' },
};
const defaultGradient = { from: '#1B3558', to: '#2D6A9F', accent: '#4D8DB5' };
---

<BaseLayout
  title="ブログ | Hareka"
  description="HubSpotの活用Tips、CRM導入・移管のポイント、AIを活用した業務効率化など、営業・マーケティング・オペレーション担当者に役立つ情報を発信します。"
  ogUrl="https://hareka.io/blog"
>
  <style>
    /* ── Filter bar ── */
    .filter-bar {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 36px;
    }
    .filter-btn {
      padding: 7px 18px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
      border: 1.5px solid #D0D9E3;
      color: #4A5568;
      background: #fff;
      cursor: pointer;
      transition: background .18s, color .18s, border-color .18s;
      white-space: nowrap;
    }
    .filter-btn:hover {
      border-color: #4D8DB5;
      color: #1B3558;
    }
    .filter-btn.active {
      background: #1B3558;
      color: #fff;
      border-color: #1B3558;
    }

    /* ── Post count ── */
    .post-count {
      font-size: 13px;
      color: #718096;
      margin-bottom: 24px;
    }
    .post-count strong {
      color: #1B3558;
      font-weight: 700;
    }

    /* ── Grid ── */
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }
    @media (max-width: 900px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .blog-grid { grid-template-columns: 1fr; } }

    /* ── Card ── */
    .blog-card {
      background: #fff;
      border: 1px solid #E2EBF3;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(27,53,88,.06);
      transition: box-shadow .2s, transform .2s, border-color .2s;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
    }
    .blog-card:hover {
      box-shadow: 0 8px 28px rgba(27,53,88,.14);
      border-color: #4D8DB5;
      transform: translateY(-4px);
    }

    /* Thumbnail */
    .card-thumb {
      width: 100%;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      position: relative;
      flex-shrink: 0;
    }
    .card-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .card-thumb__gradient {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: flex-end;
      padding: 14px 16px;
    }
    .card-thumb__category {
      font-size: 11px;
      font-weight: 700;
      color: rgba(255,255,255,.85);
      background: rgba(0,0,0,.28);
      border: 1px solid rgba(255,255,255,.25);
      padding: 3px 10px;
      border-radius: 12px;
      backdrop-filter: blur(4px);
    }

    /* Body */
    .card-body {
      padding: 20px 22px 22px;
      display: flex;
      flex-direction: column;
      flex: 1;
      gap: 10px;
    }
    .card-meta {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .card-meta__cat {
      font-size: 11px;
      font-weight: 700;
      color: #4D8DB5;
      background: #EBF4FA;
      padding: 3px 10px;
      border-radius: 10px;
    }
    .card-meta__date {
      font-size: 12px;
      color: #9AA5B4;
    }
    .card-meta__read {
      font-size: 12px;
      color: #9AA5B4;
      margin-left: auto;
      white-space: nowrap;
    }
    .card-title {
      font-size: 15px;
      font-weight: 700;
      color: #1B3558;
      line-height: 1.55;
      flex: 1;
    }
    .card-desc {
      font-size: 13px;
      color: #5A6B7E;
      line-height: 1.75;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card-readmore {
      font-size: 13px;
      color: #4D8DB5;
      font-weight: 600;
      margin-top: auto;
    }

    /* ── Coming soon ── */
    .blog-coming-soon {
      background: #F7FAFC;
      border: 1px dashed #CBD5E0;
      border-radius: 16px;
      padding: 72px 40px;
      text-align: center;
    }
    .blog-coming-soon__icon {
      width: 64px; height: 64px;
      background: rgba(77,141,181,.10);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 20px;
      color: #4D8DB5;
    }
    .blog-coming-soon__title {
      font-size: 20px;
      font-weight: 700;
      color: #1B3558;
      margin-bottom: 10px;
    }
    .blog-coming-soon__text {
      font-size: 14px;
      color: #718096;
      line-height: 1.8;
      max-width: 440px;
      margin: 0 auto;
    }
  </style>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container">
      <span class="page-hero__label">Blog</span>
      <h1 class="page-hero__title">ブログ</h1>
      <p class="page-hero__lead">HubSpotの活用Tips、CRM導入・移管のポイント、AIを活用した業務効率化など、営業・マーケティング・オペレーション担当者に役立つ情報を発信します。</p>
    </div>
  </section>

  <!-- BLOG CONTENT -->
  <section class="section">
    <div class="container">

      {allPosts.length > 0 ? (
        <>
          <!-- Filter bar -->
          <div class="filter-bar" id="filter-bar">
            {categories.map((cat, i) => (
              <button class={`filter-btn${i === 0 ? ' active' : ''}`} data-category={cat}>
                {cat}
              </button>
            ))}
          </div>

          <!-- Post count -->
          <p class="post-count" id="post-count">
            <strong>{allPosts.length}</strong> 件の記事
          </p>

          <!-- Grid -->
          <div class="blog-grid" id="blog-grid">
            {postMeta.map(post => {
              const grad = categoryGradients[post.data.category] ?? defaultGradient;
              return (
                <a
                  href={`/blog/${post.slug}`}
                  class="blog-card"
                  data-category={post.data.category}
                  data-tags={(post.data.tags ?? []).join(',')}
                >
                  {/* Thumbnail */}
                  <div class="card-thumb">
                    {post.data.heroImage ? (
                      <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                    ) : (
                      <div
                        class="card-thumb__gradient"
                        style={`background: linear-gradient(135deg, ${grad.from} 0%, ${grad.to} 100%);`}
                      >
                        <span class="card-thumb__category">{post.data.category}</span>
                      </div>
                    )}
                  </div>

                  {/* Body */}
                  <div class="card-body">
                    <div class="card-meta">
                      <span class="card-meta__cat">{post.data.category}</span>
                      <time class="card-meta__date" datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString('ja-JP')}
                      </time>
                      <span class="card-meta__read">📖 {post.readTime} 分</span>
                    </div>
                    <h2 class="card-title">{post.data.title}</h2>
                    <p class="card-desc">{post.data.description}</p>
                    <span class="card-readmore">続きを読む →</span>
                  </div>
                </a>
              );
            })}
          </div>
        </>
      ) : (
        <div class="blog-coming-soon">
          <div class="blog-coming-soon__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h2 class="blog-coming-soon__title">記事を準備中です</h2>
          <p class="blog-coming-soon__text">HubSpotの活用Tips、CRM導入・移管のベストプラクティス、AIを活用した業務効率化など、現場で役立つ情報を順次公開予定です。</p>
        </div>
      )}

    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container">
      <div class="cta-banner__inner">
        <div>
          <h2 class="cta-banner__title">記事の更新をいち早く受け取る</h2>
          <p class="cta-banner__text">お問い合わせ時にブログ更新通知をご希望いただけます。</p>
        </div>
        <a href="/contact" class="btn btn--blue btn--lg">お問い合わせ</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const blogCards = document.querySelectorAll<HTMLElement>('.blog-card');
  const postCount = document.getElementById('post-count');

  function updateCount(visible: number) {
    if (postCount) {
      postCount.innerHTML = `<strong>${visible}</strong> 件の記事`;
    }
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.dataset.category;
      let count = 0;
      blogCards.forEach(card => {
        const show = cat === 'すべて' || card.dataset.category === cat;
        card.style.display = show ? '' : 'none';
        if (show) count++;
      });
      updateCount(count);
    });
  });
</script>
